  .sticky-tab-title {
    font-size: 14px;
    font-weight: 700;
    color: white;
    letter-spacing: -0.2px;
  }
  .sticky-tab-divider {
    width: 1px; height: 16px;
    background: rgba(255,255,255,0.2);
    margin: 0 4px;
  }
  .sticky-tab-sub {
    font-size: 12px;
    color: rgba(255,255,255,0.5);
  }
  @media (max-width: 768px) {
