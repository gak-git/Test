function loadGallery() {
  const fy = document.getElementById('edit-sel-fy').value;
  const qSel = document.getElementById('edit-sel-quarter');
  const qText = qSel.options[qSel.selectedIndex].text;
  const manager = document.getElementById('edit-sel-manager').value;
