function positionPanel(btn) {
  const panel = document.getElementById('info-panel-inner');
  if (!panel.classList.contains('visible')) return;
  const btnRect = btn.getBoundingClientRect();
  const panelW = 280;
  const panelH = panel.scrollHeight || 400;
  const vh = window.innerHeight;
  const vw = window.innerWidth;
  if (vw <= 768) return; // mobile uses bottom sheet CSS
  panel.style.left = (vw - panelW - 16) + 'px';
  panel.style.width = panelW + 'px';
  let top = btnRect.top;
  if (top + panelH > vh - 10) top = vh - panelH - 10;
  if (top < 68) top = 68;
  panel.style.top = top + 'px';
}

