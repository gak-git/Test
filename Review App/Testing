  expectations: ['exp-your','exp-notes']
};

function getTabStatus(tab) {
  const required = REQUIRED[tab] || [];
  const optional = OPTIONAL[tab] || [];

  const reqFilled = required.filter(id => {
    const el = document.getElementById(id);
    return el && el.value && el.value.trim() !== '';
  }).length;

  const optFilled = optional.filter(id => {
    const el = document.getElementById(id);
    return el && el.value && el.value.trim() !== '';
  }).length;

  if (reqFilled === 0 && optFilled === 0) return 'empty';
  if (reqFilled < required.length) return 'partial';
  if (optFilled === 0 && optional.length > 0) return 'partial';
  return 'complete';
}

function markTouched(tab) {
  touchedTabs.add(tab);
  updateProgress();
}

function updateProgress() {
  ['goals','values','gwc','expectations'].forEach(tab => {
    const dot = document.getElementById('dot-' + tab);
    const row = document.getElementById('prog-' + tab);
    if (!dot || !row) return;
    dot.classList.remove('active','partial','empty','complete');
    row.classList.remove('active','partial','empty','complete');

    if (tab === currentTab) {
      dot.classList.add('active');
      row.classList.add('active');
    } else if (touchedTabs.has(tab)) {
      const status = getTabStatus(tab);
      dot.classList.add(status);
      row.classList.add(status);
    }
  });
}

