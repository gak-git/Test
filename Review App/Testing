  @media print {
    .tabs, .form-nav, .left-panel, .info-panel, .header { display: none; }
    .main-content { margin: 0; }
    .form-panel { box-shadow: none; border: 1px solid #ccc; }
  }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    .header { padding: 0 16px; height: 52px; }
    .header-brand { font-size: 13px; }
    .header-subtitle { display: none; }
    .header-divider:last-of-type { display: none; }
    .screen-toggle { gap: 2px; }
    .screen-btn { font-size: 11px; padding: 4px 10px; }

    .new-screen.app-layout, .edit-screen.app-layout {
      flex-direction: column;
      padding: 12px 12px 100px;
      gap: 12px;
    }
    .left-panel, .edit-gallery { width: 100%; position: static; }
    .fy-row { gap: 8px; }
    .main-content, .edit-main { margin-left: 0; width: 100%; }

    .tabs {
      gap: 3px; padding: 4px 4px 0 4px;
      overflow-x: auto; flex-wrap: nowrap;
      -webkit-overflow-scrolling: touch; margin-bottom: 0;
    }
    .tab-btn {
      font-size: 12px; padding: 8px 10px;
      white-space: nowrap; flex-shrink: 0;
