    list.innerHTML = '<div class="gallery-header">Submitted Reviews</div><div class="gallery-empty"><span class="gallery-empty-icon">⚠️</span><div class="gallery-empty-text">Could not load reviews</div><div class="gallery-empty-sub">Check your connection and try again</div></div>';
  };
