function renderGallery(reviews) {
  const list = document.getElementById('gallery-list');
  if (reviews.length === 0) {
    list.innerHTML = '<div class="gallery-header">Submitted Reviews</div><div class="gallery-empty"><span class="gallery-empty-icon">📭</span><div class="gallery-empty-text">No reviews found</div><div class="gallery-empty-sub">No reviews for this FY and quarter</div></div>';
    return;
  }
  let html = '<div class="gallery-header">Submitted Reviews</div>';
  reviews.forEach(r => {
    html += `<div class="gallery-item" onclick="selectReview(${r._rowIndex})">
      <div>
        <div class="gallery-item-name">${r.employee || 'Unknown'}</div>
        <div class="gallery-item-meta">${r.manager || ''} · FY${r.fy} ${r.quarter}</div>
      </div>
      <span class="gallery-item-arrow">›</span>
    </div>`;
  });
  list.innerHTML = html;
}

function selectReview(rowIndex) {
  selectedRowIndex = rowIndex;
  const r = allReviews.find(x => x._rowIndex === rowIndex);
  if (!r) return;
  document.querySelectorAll('.gallery-item').forEach(el => el.classList.remove('selected'));
  event.currentTarget.classList.add('selected');
  document.getElementById('edit-no-selection').style.display = 'none';
  document.getElementById('edit-form-wrap').style.display = 'block';
  document.getElementById('edit-save-btn').style.display = 'flex';
  const fy = r.fy || '26';
  const prevFY = String(parseInt(fy) - 1);
  const qSel = document.getElementById('edit-sel-quarter');
  const qVal = qSel.value;
  const qText = qSel.options[qSel.selectedIndex].text;
  document.getElementById('edit-fy-prev-label').textContent = `FY${prevFY} Goals`;
  document.getElementById('edit-fy-next-label').textContent = `FY${fy} Goals`;
  document.getElementById('edit-fy-perf-label').textContent = `FY${prevFY} Performance`;
  document.getElementById('edit-q-goals-label').textContent = `Q${qVal} Goals`;
  document.getElementById('edit-q-perf-label').textContent = `Q${qVal} Performance`;
  document.getElementById('edit-goals-quarter-label').textContent = qText;
  document.getElementById('edit-annual-section').style.display = qVal === '4' ? 'block' : 'none';
  const set = (id, val) => { const el = document.getElementById(id); if (el) el.value = val || ''; };
  const setSelect = (id, val) => {
    const el = document.getElementById(id); if (!el) return;
    for (let o of el.options) { if (o.value === val || o.text === val) { el.value = o.value; return; } }
    el.value = '';
  };
  set('edit-fy-prev-goals', r.previousFYGoals); set('edit-fy-next-goals', r.reviewFYGoals);
  setSelect('edit-fy-performance', r.fyPerformance); set('edit-fy-perf-comments', r.fyPerformanceComments);
  set('edit-q-goals', r.qGoals); setSelect('edit-q-performance', r.qPerformance);
  set('edit-q-perf-comments', r.qPerformanceComments); set('edit-emp-aspirations', r.employeeAspirations);
  setSelect('edit-val-real', r.weKeepItReal); set('edit-val-real-comments', r.weKeepItRealComments);
  setSelect('edit-val-ownership', r.extremeOwnership); set('edit-val-ownership-comments', r.extremeOwnershipComments);
  setSelect('edit-val-beyond', r.goBeyond); set('edit-val-beyond-comments', r.goBeyondComments);
  setSelect('edit-val-energy', r.optimisticEnergy); set('edit-val-energy-comments', r.optimisticEnergyComments);
  setSelect('edit-val-growth', r.growthMindset); set('edit-val-growth-comments', r.growthMindsetComments);
  setSelect('edit-gwc-g', r.getsIt); set('edit-gwc-g-comments', r.getsItComments);
  setSelect('edit-gwc-w', r.wantsIt); set('edit-gwc-w-comments', r.wantsItComments);
  setSelect('edit-gwc-c', r.capacity); set('edit-gwc-c-comments', r.capacityComments);
  set('edit-exp-your', r.expectations); set('edit-exp-notes', r.managerNotes);
}

function switchEditTab(tab) {
  document.querySelectorAll('#edit-form-wrap .tab-content').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('#edit-form-wrap .tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('edit-tab-' + tab).classList.add('active');
  const idx = ['goals','values','gwc','expectations'].indexOf(tab);
  document.querySelectorAll('#edit-form-wrap .tab-btn')[idx].classList.add('active');
}

function saveEdit() {
  if (selectedRowIndex === null) return;
  const btn = document.getElementById('edit-save-btn');
  btn.textContent = 'Saving…'; btn.disabled = true;
  const payload = {
    action: 'update', rowIndex: selectedRowIndex,
    previousFYGoals: document.getElementById('edit-fy-prev-goals').value,
    reviewFYGoals: document.getElementById('edit-fy-next-goals').value,
    fyPerformance: document.getElementById('edit-fy-performance').value,
    fyPerformanceComments: document.getElementById('edit-fy-perf-comments').value,
    qGoals: document.getElementById('edit-q-goals').value,
    qPerformance: document.getElementById('edit-q-performance').value,
    qPerformanceComments: document.getElementById('edit-q-perf-comments').value,
    employeeAspirations: document.getElementById('edit-emp-aspirations').value,
    weKeepItReal: document.getElementById('edit-val-real').value,
    weKeepItRealComments: document.getElementById('edit-val-real-comments').value,
    extremeOwnership: document.getElementById('edit-val-ownership').value,
    extremeOwnershipComments: document.getElementById('edit-val-ownership-comments').value,
    goBeyond: document.getElementById('edit-val-beyond').value,
    goBeyondComments: document.getElementById('edit-val-beyond-comments').value,
    optimisticEnergy: document.getElementById('edit-val-energy').value,
    optimisticEnergyComments: document.getElementById('edit-val-energy-comments').value,
    growthMindset: document.getElementById('edit-val-growth').value,
    growthMindsetComments: document.getElementById('edit-val-growth-comments').value,
    getsIt: document.getElementById('edit-gwc-g').value,
    getsItComments: document.getElementById('edit-gwc-g-comments').value,
    wantsIt: document.getElementById('edit-gwc-w').value,
    wantsItComments: document.getElementById('edit-gwc-w-comments').value,
    capacity: document.getElementById('edit-gwc-c').value,
    capacityComments: document.getElementById('edit-gwc-c-comments').value,
    expectations: document.getElementById('edit-exp-your').value,
    managerNotes: document.getElementById('edit-exp-notes').value,
  };
  const url = SCRIPT_URL + '?data=' + encodeURIComponent(JSON.stringify(payload));
  const img = new Image();
  img.onload = img.onerror = function() {
    btn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Save Changes`;
    btn.disabled = false;
    const r = allReviews.find(x => x._rowIndex === selectedRowIndex);
    if (r) Object.assign(r, payload);
    alert('Changes saved successfully!');
  };
  img.src = url;
}
</script>
</body>
</html>
