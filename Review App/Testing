  list.innerHTML = '<div class="gallery-header">Submitted Reviews</div><div class="gallery-empty"><span class="gallery-empty-icon">⏳</span><div class="gallery-empty-text">Loading reviews...</div></div>';
  const existingScript = document.getElementById('fetch-script');
  if (existingScript) existingScript.remove();
  window._galleryCallback = function(data) {
    allReviews = data || [];
    const filtered = allReviews.filter(r =>
      String(r.fy) === String(fy) &&
      r.quarter === qText &&
      (!manager || r.manager === manager) &&
      (!employee || r.employee === employee)
    );
    renderGallery(filtered);
  };
  const s = document.createElement('script');
  s.id = 'fetch-script';
  s.src = SCRIPT_URL + '?action=getAll&callback=_galleryCallback&fy=' + fy + '&quarter=' + encodeURIComponent(qText);
