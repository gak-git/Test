    .section-icon { width: 30px; height: 30px; }
    .section-title { font-size: 16px; }
    .form-nav { gap: 8px; flex-wrap: wrap; }
    .nav-btn { font-size: 12px; padding: 8px 14px; }

    /* Hide left panel submit, show floating one */
    .submit-btn { display: none; }
    .mobile-submit { display: block; }

    /* Info panel bottom sheet */
    .info-panel-inner {
      width: calc(100vw - 24px) !important;
      left: 12px !important;
      max-height: 60vh;
      top: auto !important;
      bottom: 80px;
      position: fixed;
    }
    .gallery-list { max-height: 240px; }
    .edit-save-btn { font-size: 13px; padding: 12px 16px; }
    .progress-card { display: none; }
  }

  @media (max-width: 480px) {
    .header-brand { display: none; }
    .form-panel { padding: 16px 12px; }
    .section-title { font-size: 15px; }
  }
</style>
</head>
